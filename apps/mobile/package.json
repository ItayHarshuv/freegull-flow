{
  "name": "@freegull-flow/mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "corepack pnpm run copy:web",
    "copy:web": "corepack pnpm --filter @freegull-flow/web build:native && corepack pnpm exec capacitor copy",
    "sync": "corepack pnpm exec capacitor sync",
    "open:ios": "corepack pnpm exec capacitor open ios",
    "open:android": "corepack pnpm exec capacitor open android",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.0",
    "@capacitor/core": "^7.4.3",
    "@capacitor/haptics": "^7.0.1",
    "@capacitor/keyboard": "^7.0.1",
    "@capacitor/network": "^7.0.1",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "typescript": "^5.8.2"
  }
}
